---
import type { Meta } from "../../lib/data";

interface Props {
  meta: Meta;
}

const { meta } = Astro.props;
const tagline = meta.resumeTagline || meta.tagline;
---

<header class="mb-4 pb-3 border-b border-[var(--color-border)]">
  <h1 class="text-2xl font-bold tracking-tight">{meta.name}</h1>
  <p class="text-sm text-[var(--color-accent)] font-medium mt-0.5">{tagline}</p>
  <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-2 text-xs text-[var(--color-text-muted)]">
    <span>{meta.location}</span>
    <a href={`mailto:${meta.email}`}>{meta.email}</a>
    <span>{meta.phone}</span>
    {meta.links.linkedin && (
      <a href={meta.links.linkedin}>LinkedIn</a>
    )}
    {meta.links.github && (
      <a href={meta.links.github}>GitHub</a>
    )}
    {meta.links.website && (
      <a href={meta.links.website}>{meta.links.website.replace("https://", "")}</a>
    )}
  </div>
</header>
