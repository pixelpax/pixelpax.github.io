---
import type { Meta } from "../../lib/data";

interface Props {
  meta: Meta;
}

const { meta } = Astro.props;
const firstNameLetters = meta.firstName.split("");
const lastNameLetters = meta.lastName.split("");
---

<section class="relative min-h-screen flex items-center justify-center px-8">
  <!-- Subtle grain overlay -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 128px 128px;">
  </div>

  <div class="text-center max-w-4xl">
    <h1 class="hero-name mb-6">
      <span class="block overflow-hidden">
        {firstNameLetters.map((letter) => (
          <span class="hero-letter inline-block font-heading text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight">
            {letter}
          </span>
        ))}
      </span>
      <span class="block overflow-hidden mt-1">
        {lastNameLetters.map((letter) => (
          <span class="hero-letter inline-block font-heading text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[var(--color-accent)]">
            {letter}
          </span>
        ))}
      </span>
    </h1>

    <p class="hero-tagline text-base md:text-lg text-[var(--color-text-muted)] font-light tracking-wide opacity-0">
      {meta.tagline}
    </p>

    <div class="hero-headline mt-6 opacity-0 text-lg md:text-2xl text-[var(--color-text-muted)] font-light tracking-wide">
      <span class="rotating-text">Built fast</span>
    </div>

    <div class="hero-links flex justify-center items-center gap-5 mt-8 opacity-0">
      {meta.links.linkedin && (
        <a href={meta.links.linkedin} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      )}
      {meta.links.github && (
        <a href={meta.links.github} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      )}
      <a href={`mailto:${meta.email}`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="Email">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
      </a>
      <a href={`${import.meta.env.BASE_URL}resume`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="Download Resumé">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v5.5m0 0l-2.5-2.5M12 13.5l2.5-2.5M8 16h8"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-indicator opacity-0">
    <div class="w-px h-16 bg-gradient-to-b from-transparent via-[var(--color-text-muted)] to-transparent"></div>
  </div>
</section>
