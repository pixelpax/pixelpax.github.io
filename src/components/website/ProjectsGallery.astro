---
interface ProjectEntry {
  data: {
    name: string;
    tagline: string;
    url: string;
    repo: string;
    tags: string[];
    short: string;
  };
}

interface Props {
  entries: ProjectEntry[];
}

const { entries } = Astro.props;
---

<section id="projects" class="py-24 md:py-32 px-8 bg-[var(--color-bg-card)]">
  <div class="max-w-4xl mx-auto">
    <h2 class="section-heading font-heading text-3xl md:text-4xl font-bold mb-16 text-[var(--color-accent)]" data-animate="fade-up">
      Projects
    </h2>

    <div class="grid md:grid-cols-2 gap-6" data-animate-stagger>
      {entries.map((entry) => (
        <div class="group p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1">
          <h3 class="text-lg font-semibold mb-1 group-hover:text-[var(--color-accent)] transition-colors">
            {entry.data.url ? (
              <a href={entry.data.url}>{entry.data.name}</a>
            ) : (
              entry.data.name
            )}
          </h3>
          <p class="text-xs text-[var(--color-accent)] mb-3">{entry.data.tagline}</p>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            {entry.data.short}
          </p>

          {entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-4">
              {entry.data.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)]">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <div class="flex gap-4 mt-4">
            {entry.data.url && (
              <a href={entry.data.url} class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                Live &rarr;
              </a>
            )}
            {entry.data.repo && (
              <a href={entry.data.repo} class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                Source &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
